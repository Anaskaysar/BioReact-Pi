# BioReact-Pi UI — copy to project root as .env or export before starting the server
#
# Data source: mock (demo simulation) | hardware (live Pi/QNX edge)
BIOREACTOR_DATA_SOURCE=mock

# --- Hardware connection (only used when BIOREACTOR_DATA_SOURCE=hardware) ---
# Base URL of the edge service running on the Raspberry Pi / QNX board
BIOREACTOR_HARDWARE_URL=http://192.168.1.100:8080

# REST paths on the edge service (adjust to match your Pi API)
BIOREACTOR_HARDWARE_TELEMETRY_PATH=/api/telemetry
BIOREACTOR_HARDWARE_CAMERA_PATH=/api/camera/stream

# Request timeout and dashboard poll interval (seconds)
BIOREACTOR_HARDWARE_TIMEOUT=2.0
BIOREACTOR_POLL_INTERVAL=1.0

# --- Dashboard server ---
BIOREACTOR_HOST=0.0.0.0
BIOREACTOR_PORT=8000
BIOREACTOR_RELOAD=true

# --- AI advisor (optional) ---
# Get a key at https://aistudio.google.com/apikey — without it, the
# dashboard's "Ask AI" button just shows a "not configured" message.
GEMINI_API_KEY=
# Only the FIRST model tried — advisor.py falls through a chain of free-tier
# models on a quota/not-found error, so one running dry doesn't break the
# advisor. gemini-flash-lite-latest leads (most free headroom).
GEMINI_MODEL=gemini-flash-lite-latest

# --- Voice advisor (optional) ---
# ElevenLabs reads the Gemini advice aloud. Get a key at elevenlabs.io —
# without it, advice stays text-only. Free-tier accounts must use one of
# their own available voice IDs (list via the API); premade "library" voices
# like Rachel return HTTP 402 (paid plan required). The default below is a
# free-tier voice ("Matilda").
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX
ELEVENLABS_MODEL=eleven_multilingual_v2
